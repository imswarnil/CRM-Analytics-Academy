# Public URL, used for OG Image when running nuxt generate
NUXT_PUBLIC_SITE_URL=

# Gemini API key for the "Chat with docs" assistant (server-only). Get one from
# https://aistudio.google.com/apikey — free tier is sufficient.
NUXT_GEMINI_API_KEY=

# --- Supabase (auth + data) ---
# From the Vercel↔Supabase integration or Supabase dashboard → Settings → API.
# Public (safe in the browser):
CRMA_SUPABASE_URL=
CRMA_SUPABASE_ANON_KEY=
# Server-only (NEVER expose to the browser). The new-style secret key
# (sb_secret_…) — used for admin/moderation. Preferred over the legacy
# service_role key.
CRMA_SUPABASE_SECRET_KEY=
